<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.QuestionnaireView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:matchmaking.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="60">
        <StackPanel Spacing="24" MaxWidth="800">

            <TextBlock Text="Personality Questionnaire"
                       FontSize="28" FontWeight="Bold"/>

            <TextBlock Text="How much do you relate to the following statements?"
                       FontSize="15" Foreground="Gray"/>

            <StackPanel x:Name="QuestionsPanel" Spacing="24"/>

            <StackPanel Orientation="Horizontal" Spacing="12" 
                        HorizontalAlignment="Right" Margin="0,16,0,40">
                <Button Content="Cancel" Click="Cancel_Click"/>
                <Button x:Name="SubmitButton"
                        Content="Submit"
                        IsEnabled="False"
                        Click="Submit_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
