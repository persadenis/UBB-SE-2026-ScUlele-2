<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.EditProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:matchmaking.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="60">
        <StackPanel Orientation="Vertical" Spacing="12">
            <TextBlock Text="Profile info" FontSize="30" FontWeight="Bold"/>
            <Border x:Name="ArchivedBanner"
        Background="#FFF3CD"
        BorderBrush="#FFC107"
        BorderThickness="1"
        CornerRadius="8"
        Padding="16"
        Margin="40,0,40,0"
        Visibility="Collapsed">
                <TextBlock Text="Your profile is archived. You are not visible to other users."
               Foreground="#856404"
               FontSize="14"/>
            </Border>
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" 
        Padding="32" Margin="40,16,40,0">
                <StackPanel Spacing="20">

                    <TextBlock Text="Personal Data" FontSize="20" FontWeight="SemiBold"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Name" FontSize="13" Foreground="Gray"/>
                            <TextBlock Text="{Binding Name}" FontSize="15"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Age" FontSize="13" Foreground="Gray"/>
                            <TextBlock Text="{Binding Age}" FontSize="15"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Location" FontSize="13" Foreground="Gray"/>
                            <TextBox Text="{Binding Location, Mode=TwoWay}"
                         PlaceholderText="Enter your city"
                         HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Nationality" FontSize="13" Foreground="Gray"/>
                            <TextBlock Text="{Binding Nationality}" FontSize="15"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Star Sign" FontSize="13" Foreground="Gray"/>
                            <TextBlock Text="{Binding StarSign}" FontSize="15"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" 
                        VerticalAlignment="Center">
                            <CheckBox Content="Display star sign on profile"
                          IsChecked="{Binding DisplayStarSign, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Gender" FontSize="13" Foreground="Gray"/>
                        <RadioButtons ItemsSource="{Binding GenderOptions}"
                          SelectedItem="{Binding SelectedGender, Mode=TwoWay}"
                          MaxColumns="4"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" 
Padding="32" Margin="40,16,40,0">
                <StackPanel Spacing="20">
                    <TextBlock Text="Photos" FontSize="16" FontWeight="SemiBold"/>
                    <ListView x:Name="PhotosListView"
          SelectionMode="None"
          CanReorderItems="True"
          AllowDrop="True"
          CanDragItems="True"
          Height="140">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                    </ListView>

                    <TextBlock Text="You must have 2-6 photos. JPEG/PNG files up to 10 MB."
                   FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>


            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8"
        Padding="32" Margin="40,16,40,0">
                <StackPanel Spacing="20">

                    <TextBlock Text="Preferences" FontSize="20" FontWeight="SemiBold"/>


                    <StackPanel Spacing="8">
                        <TextBlock Text="Preferred Genders" FontSize="13" Foreground="Gray"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" x:Name="PreferredGendersPanel"/>
                    </StackPanel>


                    <StackPanel Spacing="8">
                        <TextBlock Name="AgeRangeLabel" Text="Preferred Age Range" FontSize="13" Foreground="Gray"/>
                        <Slider Name="MinAgeSlider" Minimum="18" Maximum="99" Value="{Binding MinPreferredAge, Mode=TwoWay}" />
                        <Slider Name="MaxAgeSlider" Minimum="18" Maximum="99" Value="{Binding MaxPreferredAge, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Name="DistanceLabel" Text="Maximum Distance" FontSize="13" Foreground="Gray"/>
                        <Slider Name="DistanceSlider" Minimum="1" Maximum="500" Value="{Binding MaxDistance, Mode=TwoWay}"/>
                    </StackPanel>


                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8"
                Height="280" Background="#F5F5F5">
                    </Border>

                </StackPanel>
            </Border>

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8"
        Padding="32" Margin="40,16,40,0">
                <StackPanel Spacing="20">

                    <TextBlock Text="About You" FontSize="20" FontWeight="SemiBold"/>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="BioHeader" Text="Bio (0/250)" 
                       FontSize="13" Foreground="Gray"/>
                        <TextBox x:Name="BioBox"
                     Text="{Binding Bio, Mode=TwoWay}"
                     PlaceholderText="Write about yourself..."
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Height="100"
                     HorizontalAlignment="Stretch"/>
                        <TextBlock Text="Must be between 20 and 250 characters"
                       FontSize="12" Foreground="Gray"/>
                    </StackPanel>


                    <StackPanel Spacing="8">
                        <TextBlock Name="InterestsHeader" 
                       Text="Interests (0/15)" 
                       FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Select 3-15 interests" 
                       FontSize="12" Foreground="Gray"/>
                        <VariableSizedWrapGrid Name="InterestsPanel" Orientation="Horizontal" ItemWidth="130" ItemHeight="60"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Personality Type" FontSize="13" Foreground="Gray"/>
                        <TextBlock Text="{Binding LoverTypeResultText}" FontSize="15"/>
                        <Button Name="QuestionnaireButton" Content="Take Personality Questionnaire" Click="QuestionnaireButton_Click"/>
                  
                    </StackPanel>

                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right"
                        Margin="40,24,40,0">
                <Button Content="Save changes"
                        Click="SaveChanges_Click"/>
                <Button Content="Discard changes"
                        Click="DiscardChanges_Click"/>
                <Button Content="Archive profile"
                        Click="ArchiveProfile_Click"
                        IsEnabled="{Binding IsNotArchived}"/>

                <Button Content="Unarchive profile"
                        Click="UnarchiveProfile_Click"
                        IsEnabled="{Binding IsArchived}"/>
                <Button Content="Delete profile" Click="DeleteProfile_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>