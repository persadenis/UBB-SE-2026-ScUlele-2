<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="matchmaking.Views.DiscoverView"
    x:Name="DiscoverViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    KeyDown="Page_KeyDown">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#eb3b59">
        </Grid>

        <Border Grid.RowSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="40,20,40,0"
                Padding="16,12"
                CornerRadius="10"
                Background="#CCB00020"
                BorderBrush="#FFFF6B6B"
                BorderThickness="1"
                Visibility="{x:Bind ViewModel.ErrorMessageVisibility, Mode=OneWay}"
                Canvas.ZIndex="400">
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="0" Visibility="{x:Bind ViewModel.CandidatesVisibility, Mode=OneWay}" Margin="40,20,40,20" CornerRadius="12" Background="#2B2B2B" BorderBrush="#2B2B2B" BorderThickness="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" CornerRadius="12,0,0,12" Background="Black">
                <Image Source="{x:Bind ViewModel.CurrentPhoto.Location, Mode=OneWay, TargetNullValue='ms-appx:///Assets/placeholder.png'}" Stretch="UniformToFill"/>
                <Button Click="PreviousPhotoButton_Click" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#AA000000" Foreground="White" Margin="10" Height="50" Width="50" CornerRadius="25"/>
                <Button Click="NextPhotoButton_Click" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" VerticalAlignment="Center" Background="#AA000000" Foreground="White" Margin="10" Height="50" Width="50" CornerRadius="25"/>
            </Grid>

            <ScrollViewer Grid.Column="1" Padding="30">
                <StackPanel Spacing="15">
                    <TextBlock Text="{x:Bind ViewModel.CurrentValidCandidate.Name, Mode=OneWay, TargetNullValue='N/A'}" FontSize="36" FontWeight="Bold" Foreground="White"/>

                    <StackPanel Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CurrentValidCandidate.Age, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentValidCandidate.Gender, Mode=OneWay}" FontSize="20" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE139;" Foreground="White" FontSize="18"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentValidCandidate.Location, Mode=OneWay}" FontSize="18" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE12B;" Foreground="White" FontSize="18"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentValidCandidate.Nationality, Mode=OneWay}" FontSize="18" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" 
                               Visibility="{x:Bind ViewModel.CurrentCandidateStarSignVisibility, Mode=OneWay}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE728;" Foreground="White" FontSize="18"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentCandidateStarSign, Mode=OneWay}" FontSize="18" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                               Visibility="{x:Bind ViewModel.CurrentCandidateLoverTypeVisibility, Mode=OneWay}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" Foreground="White" FontSize="18"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentCandidateLoverType, Mode=OneWay}" FontSize="18" Foreground="White"/>
                    </StackPanel>

                    <MenuFlyoutSeparator Margin="0,10,0,10" Background="White" Opacity="0.5"/>

                    <TextBlock Text="Description" FontWeight="SemiBold" FontSize="20" Foreground="White"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentValidCandidate.Bio, Mode=OneWay}" TextWrapping="Wrap" FontSize="16" Foreground="White"/>

                    <MenuFlyoutSeparator Margin="0,10,0,10" Background="White" Opacity="0.5"/>

                    <TextBlock Text="Interests" FontWeight="SemiBold" FontSize="20" Foreground="White" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentValidCandidate.Interests, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border CornerRadius="6" Padding="12,8" BorderThickness="2" BorderBrush="White" Background="Transparent">
                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <MenuFlyoutSeparator Margin="0,10,0,10" Background="White" Opacity="0.5"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Common communities" FontWeight="SemiBold" FontSize="20" Foreground="White"/>
                        <TextBlock Text="{x:Bind ViewModel.CommonCommunitiesText, Mode=OneWay}" TextWrapping="Wrap" FontStyle="Italic" FontSize="16" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="0" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                   Visibility="{x:Bind ViewModel.NoCandidatesVisibility, Mode=OneWay}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24" FontWeight="Bold" Foreground="White"/>

        <Grid Grid.Row="1" Margin="0,20,0,20" Visibility="{x:Bind ViewModel.DiscoverActionsVisibility, Mode=OneWay}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="40" VerticalAlignment="Center">
                <Button Click="PassButton_Click" Width="80" Height="80" CornerRadius="40" Background="Transparent" BorderBrush="#eb3b59" BorderThickness="4" IsEnabled="{x:Bind ViewModel.HasCandidates, Mode=OneWay}">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" Foreground="#eb3b59" FontSize="44"/>
                </Button>
                <Button Click="SuperLikeButton_Click" Width="80" Height="80" CornerRadius="40" Background="Transparent" BorderBrush="#00A4FF" BorderThickness="4" IsEnabled="{x:Bind ViewModel.HasCandidates, Mode=OneWay}">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE735;" Foreground="#00A4FF" FontSize="44"/>
                </Button>
                <Button Click="LikeButton_Click" Width="80" Height="80" CornerRadius="40" Background="Transparent" BorderBrush="#1CEE91" BorderThickness="4" IsEnabled="{x:Bind ViewModel.HasCandidates, Mode=OneWay}">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" Foreground="#1CEE91" FontSize="44"/>
                </Button>
            </StackPanel>
            <Button Click="HelpButton_Click" Width="60" Height="60" CornerRadius="35" Background="Transparent" BorderBrush="#9370DB" BorderThickness="4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE897;" Foreground="#9370DB" FontSize="24"/>
            </Button>
        </Grid>

        <Grid Visibility="{x:Bind ViewModel.GuideVisibility, Mode=OneWay}" Background="#DD000000" Grid.RowSpan="2" Canvas.ZIndex="100" Tapped="Guide_Tapped">

            <TextBlock Text="Tutorial for Discover" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,120,0,0"/>

            <TextBlock Text="Press ESC or click anywhere to exit the guide." Foreground="LightGray" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20"/>

            <Grid VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Spacing="40" VerticalAlignment="Center">

                    <Canvas Width="80" Height="80">
                        <Ellipse Canvas.Left="-10" Canvas.Top="-10" Width="100" Height="100" Stroke="White" StrokeThickness="3" StrokeDashArray="3 3"/>
                        <TextBlock Canvas.Left="-30" Canvas.Top="-50" Text="&#x2196;" FontSize="40" Foreground="White" />
                        <TextBlock Canvas.Left="-160" Canvas.Top="-120" Text="Skip if you are not interested in this profile" Width="150" TextWrapping="Wrap" TextAlignment="Right" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                        <Button Width="80" Height="80" CornerRadius="40" Background="Black" BorderBrush="#eb3b59" BorderThickness="4" IsEnabled="False">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" Foreground="#eb3b59" FontSize="44"/>
                        </Button>
                    </Canvas>

                    <Canvas Width="80" Height="80">
                        <Ellipse Canvas.Left="-10" Canvas.Top="-10" Width="100" Height="100" Stroke="White" StrokeThickness="3" StrokeDashArray="3 3"/>
                        <TextBlock Canvas.Left="25" Canvas.Top="-55" Text="&#x2191;" FontSize="40" Foreground="White" />
                        <TextBlock Canvas.Left="-50" Canvas.Top="-140" Text="Super-like this profile, this will send them a notification" Width="180" TextWrapping="Wrap" TextAlignment="Center" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                        <Button Width="80" Height="80" CornerRadius="40" Background="Black" BorderBrush="#00A4FF" BorderThickness="4" IsEnabled="False">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE735;" Foreground="#00A4FF" FontSize="44"/>
                        </Button>
                    </Canvas>

                    <Canvas Width="80" Height="80">
                        <Ellipse Canvas.Left="-10" Canvas.Top="-10" Width="100" Height="100" Stroke="White" StrokeThickness="3" StrokeDashArray="3 3"/>
                        <TextBlock Canvas.Left="75" Canvas.Top="-50" Text="&#x2197;" FontSize="40" Foreground="White" />
                        <TextBlock Canvas.Left="90" Canvas.Top="-120" Text="Like if you are interested in this profile" Width="150" TextWrapping="Wrap" TextAlignment="Left" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                        <Button Width="80" Height="80" CornerRadius="40" Background="Black" BorderBrush="#1CEE91" BorderThickness="4" IsEnabled="False">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" Foreground="#1CEE91" FontSize="44"/>
                        </Button>
                    </Canvas>

                </StackPanel>
            </Grid>
        </Grid>

        <Grid Visibility="{x:Bind ViewModel.MatchPopupVisibility, Mode=OneWay}" Background="#CC000000" Grid.RowSpan="2" Canvas.ZIndex="200">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="50" CornerRadius="15" Spacing="25" BorderBrush="HotPink" BorderThickness="2">
                <TextBlock Text="IT'S A MATCH!" FontSize="36" FontWeight="Bold" Foreground="HotPink" HorizontalAlignment="Center"/>

                <Grid Width="420" Height="240" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xEB51;" FontFamily="Segoe MDL2 Assets" FontSize="220" Foreground="HotPink" Opacity="0.25" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.MatchPopupMessage, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" TextWrapping="WrapWholeWords" MaxWidth="320" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                </Grid>

                <Button Content="Keep Swiping" Click="CloseMatchPopupButton_Click" HorizontalAlignment="Center" Background="HotPink" Foreground="White" FontSize="18" Padding="20,10"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>